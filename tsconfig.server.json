{
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node",
      "target": "ES2022",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "allowJs": true,
      "noEmit": false
    },
    "include": ["server.ts", "api/**/*.ts"],
    "exclude": ["node_modules", "contracts-workspace", "dist"]
  }